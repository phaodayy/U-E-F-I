<?xml version="1.0" encoding="UTF-8"?>
<project name="GZ-Valorant" version="1.0">
    <metadata>
        <description>Kernel-level software for memory interaction with Valorant (Unreal Engine 4).</description>
        <target_process>VALORANT-Win64-Shipping.exe</target_process>
        <development_status>Active</development_status>
        <security_level>High (Kernel-mode bypass, Anti-anti-cheat measures)</security_level>
    </metadata>

    <architecture>
        <component type="KernelDriver" directory="./driver">
            <purpose>Bypass CR3 protection and provide read/write/query services to user-mode via system hooks.</purpose>
            <features>
                <feature>Physical memory reading (TranslateLinear)</feature>
                <feature>Direct CR3 manipulation (directory_table_base)</feature>
                <feature>Hooking HalPrivateDispatchTable</feature>
            </features>
        </component>
        <component type="UserClient" directory="./valorant">
            <purpose>Main logic, GUI (ImGui Overlay), and SDK management.</purpose>
            <features>
                <feature>ImGui-based Menu &amp; Overlay</feature>
                <feature>Cloud-based Offset Synchronizer</feature>
                <feature>License Authentication (GZAuth)</feature>
            </features>
        </component>
        <component type="SharedData" directory="./.shared">
            <purpose>Protocols and packet definitions used by both Driver and Client.</purpose>
        </component>
    </architecture>

    <communication_protocol>
        <method>Hook on HalTimerQueryAuxiliaryCounterFrequency</method>
        <trigger_function>NtQueryAuxiliaryCounterFrequency (exported from ntdll.dll)</trigger_function>
        <packet_structure name="c_packet">
            <field name="m_syscall">Operation type (e_syscall)</field>
            <field name="m_buffer">Pointer to operation-specific data packet</field>
            <field name="m_size">Size of the data packet</field>
        </packet_structure>
        <syscalls>
            <syscall id="1">read_process_memory</syscall>
            <syscall id="2">write_process_memory</syscall>
            <syscall id="3">query_process_data</syscall>
        </syscalls>
    </communication_protocol>

    <driver_internals>
        <hooks>
            <hook target="HalTimerQueryAuxiliaryCounterFrequency">Handles R/W and Query packets by intercepting TrapFrame->Rdx.</hook>
            <hook target="HalClearLastBranchRecordStack">Updates EPROCESS->DirectoryTableBase (0x28) with the current CR3 to prevent translation failures.</hook>
        </hooks>
        <security>
            <measure type="CallSpoofing">Uses ret::spoof_call for kernel system routine calls to hide caller identity.</measure>
            <measure type="StackProtection">KiCpuTracingFlags bit manipulation to enable specific hardware features for concealment.</measure>
        </security>
    </driver_internals>

    <client_internals>
        <initialization_flow>
            <step>Check driver communication via query_process_data syscall.</step>
            <step>Authenticate license key via GZAuth.</step>
            <step>Wait for target process (VALORANT-Win64-Shipping.exe).</step>
            <step>Fetch encrypted offsets from cloud backend.</step>
            <step>Initialize ValorantContext (UE4 Engine Connection).</step>
            <step>Launch Overlay and GameData update thread.</step>
        </initialization_flow>
        <security>
            <measure type="StringEncryption">Uses skCrypt for literal strings.</measure>
            <measure type="CloudOffsets">Fetches sensitive memory offsets from a remote URL to prevent static analysis of older binaries.</measure>
            <measure type="XOR_Storage">Offsets are XORed with a session-unique g_StorageKey (derived from system time).</measure>
        </security>
    </client_internals>

    <sdk_specification>
        <engine_base>Unreal Engine 4</engine_base>
        <core_offsets>
            <offset name="GWorld" encryption="XORed">Global game world object.</offset>
            <offset name="FNamePool" encryption="XORed">String storage and translation.</offset>
            <offset name="LocalPlayers" path="GWorld->GameInstance->LocalPlayers">Array of local player controllers.</offset>
            <offset name="ActorArray" path="GWorld->PersistentLevel->ActorArray">List of all entities in the level.</offset>
        </core_offsets>
        <entity_logic>
            <logic type="HealthCheck">Accessed via DamageHandler -> Health.</logic>
            <logic type="TeamCheck">Accessed via TeamComponent -> TeamID.</logic>
            <logic type="Skeleton">BoneArray accessed through Mesh component.</logic>
        </entity_logic>
    </sdk_specification>
</project>
